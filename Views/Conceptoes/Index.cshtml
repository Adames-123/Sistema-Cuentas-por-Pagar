@model IEnumerable<Sistema_Documentos_por_Pagar.Models.Concepto>
@{
    ViewData["Title"] = "Conceptos";
}

<div class="crud-container">
    <div class="crud-header">
        <div>
            <h2 class="crud-title">Conceptos</h2>
            <p class="crud-subtitle">Clasificación de documentos</p>
        </div>
        <a asp-action="Create" class="btn-primary">
            <i class="fas fa-plus"></i> Nuevo concepto
        </a>
    </div>

    <div class="crud-table-wrapper">
        <div class="table-responsive">
            <table class="crud-table">
                <thead>
                    <tr>
                        <th>Descripción</th>
                        <th>Estado</th>
                        <th style="text-align:right">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Descripcion</strong></td>
                                <td>
                                    @if (item.Estado)
                                    {
                                        <span style="
                                    padding: 5px 14px;
                                    border-radius: 20px;
                                    font-size: 0.82rem;
                                    font-weight: 600;
                                    border: 2px solid #2e7d32;
                                    background: white;
                                    color: #2e7d32;
                                                background: #dbeddc;
                                    display: inline-block;">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span style="
                                    padding: 5px 14px;
                                    border-radius: 20px;
                                    font-size: 0.82rem;
                                    font-weight: 600;
                                    border: 2px solid #c62828;
                                    background: white;
                                    color: #c62828;
                                    background-color: #FEEBE7;
                                    display: inline-block;">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td>
                                    <div class="actions">
                                        <a asp-action="Details"
                                           asp-route-id="@item.IdConcepto"
                                           class="btn-action view" title="Ver">
                                            <i class="fas fa-eye"></i>
                                        </a>
                                        <a asp-action="Edit"
                                           asp-route-id="@item.IdConcepto"
                                           class="btn-action edit" title="Editar">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <form asp-action="Delete" method="post" style="display:inline;" id="form-con-@item.IdConcepto">
                                            <input type="hidden" name="id" value="@item.IdConcepto" />
                                            <button type="button"
                                                    class="btn-action delete"
                                                    title="Eliminar"
                                                    onclick="confirmDeleteConcepto(@item.IdConcepto)">
                                                <i class="fas fa-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="3" style="text-align:center; padding:32px; color:#999;">
                                No hay conceptos registrados
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        <div class="tabla-footer">
            Mostrando @Model.Count() conceptos
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        function confirmDeleteConcepto(id) {
            Swal.fire({
                title: '¿Eliminar concepto?',
                text: "Esta acción no se puede deshacer",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#276B3F',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    document.getElementById('form-con-' + id).submit();
                }
            });
        }
    </script>
}