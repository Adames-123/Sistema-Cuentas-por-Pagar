@model Sistema_Documentos_por_Pagar.Models.Proveedor

@{
    ViewData["Title"] = "Editar proveedor";
}

<div class="dp-create">

    <div class="dp-create__header">
        <h1 class="dp-create__title">Editar proveedor</h1>
        <p class="dp-create__subtitle">Modifica la información del proveedor</p>
    </div>

    <div class="dp-create__card">
        <form asp-action="Edit">

            <input type="hidden" asp-for="IdProveedor" />

            <div asp-validation-summary="ModelOnly" class="dp-create__error mb-3"></div>

            <span class="dp-create__section-label">Información del proveedor</span>

            <div class="dp-create__field">
                <label class="dp-create__label" asp-for="Nombre"></label>
                <input asp-for="Nombre" class="dp-create__input" />
                <span asp-validation-for="Nombre" class="dp-create__error"></span>
            </div>

            <div class="dp-create__field">
                <label class="dp-create__label" asp-for="CedulaRNC"></label>
                <input asp-for="CedulaRNC" class="dp-create__input" />
                <span asp-validation-for="CedulaRNC" class="dp-create__error"></span>
            </div>

            <div class="dp-create__field">
                <label class="dp-create__label" asp-for="Balance"></label>
                <input asp-for="Balance" class="dp-create__input" />
                <span asp-validation-for="Balance" class="dp-create__error"></span>
            </div>

            <div class="dp-create__field">
                <label class="dp-create__label" asp-for="TipoPersona"></label>
                <select asp-for="TipoPersona"
                        class="dp-create__input"
                        asp-items="ViewBag.TipoPersonaList">
                    <option value="">Seleccione...</option>
                </select>
                <span asp-validation-for="TipoPersona" class="dp-create__error"></span>
            </div>

            <hr class="dp-create__divider" />

            <span class="dp-create__section-label">Configuración</span>

            <div class="dp-create__toggle-row">
                <div class="dp-create__toggle-text">
                    <span class="dp-create__toggle-title">Estado del proveedor</span>
                    <span class="dp-create__toggle-sub" id="estadoLabel">
                        @(Model.Estado ? "Activo" : "Inactivo")
                    </span>
                </div>

                <label class="dp-create__switch">
                    <input type="checkbox" asp-for="Estado" id="estadoSwitch" />
                    <span class="dp-create__switch-track"></span>
                </label>
            </div>

            <div class="dp-create__footer">
                <button type="submit" class="dp-create__btn-save">Guardar cambios</button>
                <a asp-action="Index" class="dp-create__btn-back">← Volver al listado</a>
            </div>

        </form>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const sw = document.getElementById('estadoSwitch');
        const lbl = document.getElementById('estadoLabel');

        function updateLabel() {
            lbl.textContent = sw.checked ? 'Activo' : 'Inactivo';
        }

        sw.addEventListener('change', updateLabel);
        updateLabel();
    </script>
}