@model Sistema_Documentos_por_Pagar.Models.DocumentoPorPagar

@{
    ViewData["Title"] = "Detalle del documento";
}

<div class="dp-create">

    <div class="dp-create__header">
        <h1 class="dp-create__title">Detalle del documento</h1>
        <p class="dp-create__subtitle">Información completa del documento</p>
    </div>

    <div class="dp-create__card">

        <span class="dp-create__section-label">Información general</span>

        <div class="dp-detail">

            <div class="dp-detail__item">
                <span class="dp-detail__label">Proveedor</span>
                <span class="dp-detail__value">
                    @Model.Proveedor?.Nombre
                </span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Concepto</span>
                <span class="dp-detail__value">
                    @Model.Concepto?.Descripcion
                </span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Monto</span>
                <span class="dp-detail__value">@Model.Monto</span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Número de documento</span>
                <span class="dp-detail__value">@Model.NumeroDocumento</span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Número de factura</span>
                <span class="dp-detail__value">@Model.NumeroFactura</span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Fecha documento</span>
                <span class="dp-detail__value">@Model.FechaRegistro?.ToShortDateString()</span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Fecha registro</span>
                <span class="dp-detail__value">@Model.FechaRegistro?.ToShortDateString()</span>
            </div>

            <div class="dp-detail__item">
                <span class="dp-detail__label">Estado</span>
                <span class="dp-detail__value @(Model.Estado ? "activo" : "inactivo")">
                    @(Model.Estado ? "Activo" : "Inactivo")
                </span>
            </div>

        </div>

        <div class="dp-create__footer">
            <a asp-action="Edit" asp-route-id="@Model.IdDocumento" class="dp-create__btn-save">
                Editar
            </a>

            <a asp-action="Index" class="dp-create__btn-back">
                ← Volver al listado
            </a>
        </div>

    </div>

</div>